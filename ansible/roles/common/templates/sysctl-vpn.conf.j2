# Настройки ядра для VPN-сервера
# Управляется Ansible — не редактировать вручную

# Включить IP-форвардинг (обязательно для VPN)
net.ipv4.ip_forward = 1
net.ipv6.conf.all.forwarding = 1

# BBR — алгоритм контроля перегрузки (улучшает скорость)
net.core.default_qdisc = fq
net.ipv4.tcp_congestion_control = bbr

# Увеличить буферы для высоконагруженного трафика
net.core.rmem_max = 16777216
net.core.wmem_max = 16777216
net.ipv4.tcp_rmem = 4096 87380 16777216
net.ipv4.tcp_wmem = 4096 65536 16777216
