# ============================================================
# VPN Infrastructure — Конфигурация
# Генерируется автоматически через: bash setup.sh
# Или скопируйте в .env и заполните вручную.
# ============================================================

# --- Cloudflare API ---
CF_API_TOKEN=CHANGE_ME                  # API Token: Zone:DNS:Edit, Zone:Settings:Edit, Tunnel:Edit
CF_ACCOUNT_ID=CHANGE_ME                 # Account ID из CF dashboard
CF_ZONE_ID=CHANGE_ME                    # Zone ID для домена
CF_DOMAIN=example.com                   # Базовый домен

# --- Telegram Bot ---
TG_BOT_TOKEN=CHANGE_ME                  # Токен от @BotFather
TG_ADMIN_ID=CHANGE_ME                   # Числовой ID администратора

# --- AWG обфускация (общая для всех серверов и клиентов) ---
AWG_JC=4
AWG_JMIN=40
AWG_JMAX=70
AWG_S1=0
AWG_S2=0
AWG_H1=CHANGE_ME                        # Сгенерировать: shuf -i 1-2147483647 -n 1
AWG_H2=CHANGE_ME
AWG_H3=CHANGE_ME
AWG_H4=CHANGE_ME

# --- Мониторинг ---
HEALTHCHECK_INTERVAL=300                # Секунды между проверками
HEALTHCHECK_TIMEOUT=10                  # Таймаут проверки (секунды)

# --- Данные ---
DB_PATH=/data/vpn.db
DATA_DIR=/data

# ============================================================
# Серверы управляются через Telegram-бот и хранятся в SQLite.
# Ручная настройка серверов через .env больше НЕ нужна.
# ============================================================
